pico-8 cartridge // http://www.pico-8.com
version 41
__lua__
function _init()
	
end

moved = false

function _draw()
	if player.sleep != 0 then
		return
	end

	cls(13)
	
	if not moved then
		print("❎ for jump", 1)
		print("enter for pause")
	else 
		print("")
		print("   🐱 made by sadra 🐱", 7)
	end
	
	plt.draw()
	
	player.draw()
	
	mushroom.draw()
end

function _update()
	if player.sleep != 0 then
		player.sleep -= 1
		return
	end 

	player.update()
	mushroom.update()
end
-->8
--player


player = {
	x = 64,
	y = 120-16,

	sleep = 0,
	
	velocity = 0,
	
	score = 0,
	
	speed = 2,
	frame = 1,
	
	draw = function()
		spr(flr(player.frame), player.x, player.y)
		print(player.score, 2)
	end,
	
	update = function()	
		if flr(player.frame) >= 5 then
			player.frame = 1
		end
		
		if flr(player.frame) <= 0 then
			player.frame = 5
		end
		
		if btn(❎) and player.y == 120-16 then
			player.velocity -= 7
			moved = true
			sfx(0)
		end
		
		player.velocity += 1
		player.y += player.velocity
		
		if player.y >= 120-16 then
			player.velocity = 0
			player.y = 120-16
		end
		
		if moved then
			player.frame += 1
		end
		
		player.checkcoll()
	end,
	
	lose = function()
		player.score = 0
		mushroom.x = 120
		print("you lose 웃", 8)
	end,
	
	checkcoll = function()
		for x = player.x,player.x+8 do
			if mushroom.x == x then
				for y = player.y,player.y+8 do
					if mushroom.y == y then
						player.lose()
						return true
					end
				end
				player.score += mushroom.scorep
				mushroom.scorep = 0
				return false
			end
		end
		return false
	end
}
-->8
--platform

plt = {
	draw = function()
		for x = 0, 15 do
			spr(7, x*8, 120)
			spr(6, x*8, 120-8)
		end
	end
}
-->8
--mushroom

mushroom = {
	x = 120,
	y = 120-16,
	scorep = 1,
	
	draw = function()
		spr(8, mushroom.x, mushroom.y)
	end,
	
	update = function()
		if not moved then
			return
		end
	
		mushroom.x -= 2
		
		if mushroom.x < -8 then
			mushroom.x = 120
			mushroom.scorep = 1
		end
	end
}
